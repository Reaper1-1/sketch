{
    "name": "@frontify/frontify-plugin",
    "description": "Connecting your brand and design worlds",
    "version": "2.3.22",
    "repository": {
        "type": "git",
        "url": "https://github.com/Frontify/sketch.git"
    },
    "engines": {
        "node": ">=22",
        "sketch": ">=100.0"
    },
    "skpm": {
        "name": "frontify-plugin",
        "manifest": "src/manifest.json",
        "main": "frontify.sketchplugin"
    },
    "scripts": {
        "build": "skpm-build",
        "watch": "skpm-build --watch",
        "start": "skpm-build --watch --run",
        "postinstall": "npm run build && skpm-link"
    },
    "devDependencies": {
        "@skpm/builder": "^1.0.0",
        "@skpm/extract-loader": "2.0.3",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^7.1.4",
        "dot-tpl-loader": "1.2.1",
        "regexp-replace-loader": "1.0.1",
        "style-loader": "0.23.1",
        "@mcler/webpack-concat-plugin": "^4.1.6"
    },
    "resources": [
        "src/assets/js/*.js"
    ],
    "dependencies": {
        "@babel/runtime": "^7.20.7",
        "@skpm/child_process": "0.4.2",
        "@skpm/fs": "^0.2.6",
        "mocha-js-delegate": "0.2.0",
        "sketch-module-web-view": "^3.5.3"
    },
    "overrides": {
        "loader-utils": "1.4.2",
        "json5": "2.2.3"
    }
}
